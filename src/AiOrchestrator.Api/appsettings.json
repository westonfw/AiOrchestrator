{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Llm": {
    "Provider": "OpenAICompatible",
    "BaseUrl": "https://api.openai.com/v1",
    "DefaultModel": "gpt-4.1-mini",
    "TimeoutSeconds": 120,
    "UseJsonResponseFormat": true,
    "LogRequests": true,
    "LogDirectory": "logs/llm"
  },
  "PublicData": {
    "StooqBaseUrl": "https://stooq.com"
  },
  "AllowedHosts": "*"
}
