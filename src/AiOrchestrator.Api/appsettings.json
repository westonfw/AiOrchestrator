{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RabbitMq": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "StartWorkflowQueue": "workflow.start",
    "ContinueWorkflowQueue": "workflow.continue"
  },
  "Llm": {
    "Provider": "OpenAICompatible",
    "BaseUrl": "https://api.openai.com/v1",
    "DefaultModel": "gpt-4.1-mini",
    "TimeoutSeconds": 120,
    "UseJsonResponseFormat": true,
    "LogRequests": true,
    "LogDirectory": "logs/llm"
  },
  "PublicData": {
    "StooqBaseUrl": "https://stooq.com"
  },
  "AllowedHosts": "*"
}
