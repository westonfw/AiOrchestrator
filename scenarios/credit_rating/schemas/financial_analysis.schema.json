{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "summary",
    "strengths",
    "weaknesses",
    "key_ratios",
    "risk_level",
    "uncertainties"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "strengths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "key_ratios": {
      "type": "object",
      "additionalProperties": true
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "medium_high",
        "high",
        "unknown"
      ]
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "required": [
        "claim",
        "evidence_ids",
        "confidence"
      ],
      "properties": {
        "claim": {
          "type": "string"
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
