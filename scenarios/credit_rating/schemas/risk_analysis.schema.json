{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "summary",
    "risks",
    "overall_risk_level",
    "uncertainties"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "overall_risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "medium_high",
        "high",
        "unknown"
      ]
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "risk_type",
          "severity",
          "reason",
          "evidence_ids"
        ],
        "properties": {
          "risk_type": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "unknown"
            ]
          },
          "reason": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
