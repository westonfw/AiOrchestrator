{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "summary",
    "industry_position",
    "opportunities",
    "risks",
    "uncertainties"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "industry_position": {
      "type": "string"
    },
    "opportunities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
